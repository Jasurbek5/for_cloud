<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Online Kutubxona | Zamonaviy Raqamli Kutubxona</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    },
                    colors: {
                        primary: {
                            50: '#eff6ff',
                            100: '#dbeafe',
                            500: '#3b82f6',
                            600: '#2563eb',
                            700: '#1d4ed8',
                        }
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; }
        .scrollbar-hide::-webkit-scrollbar { display: none; }
        .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
        .glass-effect {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
        }
        .dark .glass-effect {
            background: rgba(30, 41, 59, 0.7);
        }
        .book-card-hover:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        }
        .line-clamp-3 {
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
        .dark ::-webkit-scrollbar-thumb { background: #475569; }
        .dark ::-webkit-scrollbar-thumb:hover { background: #64748b; }
    </style>
</head>
<body class="bg-gray-50 text-gray-800 dark:bg-slate-900 dark:text-gray-100 transition-colors duration-300">

    <div class="flex h-screen overflow-hidden">
        
        <!-- Sidebar -->
        <aside class="w-80 bg-white dark:bg-slate-800 border-r border-gray-200 dark:border-slate-700 flex flex-col h-full transition-colors duration-300 z-20 hidden md:flex">
            <div class="p-6 border-b border-gray-100 dark:border-slate-700">
                <div class="flex items-center gap-3 mb-6">
                    <div class="w-10 h-10 bg-gradient-to-br from-blue-500 to-purple-600 rounded-xl flex items-center justify-center text-white text-xl shadow-lg">
                        <i class="fas fa-book-open"></i>
                    </div>
                    <h1 class="text-xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-blue-600 to-purple-600">Online Kutubxona</h1>
                </div>

                <div class="flex items-center gap-4 p-4 bg-gray-50 dark:bg-slate-700/50 rounded-xl">
                    <div class="w-12 h-12 rounded-full bg-gradient-to-tr from-blue-400 to-purple-500 flex items-center justify-center text-white text-lg font-bold shadow-md">
                        K
                    </div>
                    <div>
                        <h3 class="font-semibold text-sm">Kitobxon Foydalanuvchi</h3>
                        <p class="text-xs text-gray-500 dark:text-gray-400">Premium a'zo</p>
                    </div>
                </div>
            </div>

            <div class="flex-1 overflow-y-auto p-4 space-y-6">
                <!-- Stats -->
                <div class="grid grid-cols-2 gap-3">
                    <div class="bg-blue-50 dark:bg-slate-700/50 p-3 rounded-xl text-center">
                        <div class="text-2xl font-bold text-blue-600 dark:text-blue-400" id="stat-reading">0</div>
                        <div class="text-xs text-gray-500 dark:text-gray-400">O'qilmoqda</div>
                    </div>
                    <div class="bg-green-50 dark:bg-slate-700/50 p-3 rounded-xl text-center">
                        <div class="text-2xl font-bold text-green-600 dark:text-green-400" id="stat-finished">0</div>
                        <div class="text-xs text-gray-500 dark:text-gray-400">Tugallangan</div>
                    </div>
                </div>

                <!-- Shelves -->
                <div>
                    <h4 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3 px-2">Mening javonim</h4>
                    <nav class="space-y-1">
                        <button onclick="app.filterShelf('all')" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-gray-100 dark:hover:bg-slate-700 transition-colors text-left group active-shelf" data-shelf="all">
                            <i class="fas fa-th-large text-gray-400 group-hover:text-blue-500 transition-colors"></i>
                            <span class="text-sm font-medium">Barcha kitoblar</span>
                            <span class="ml-auto text-xs bg-gray-100 dark:bg-slate-700 px-2 py-0.5 rounded-full" id="count-all">0</span>
                        </button>
                        <button onclick="app.filterShelf('reading')" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-gray-100 dark:hover:bg-slate-700 transition-colors text-left group" data-shelf="reading">
                            <i class="fas fa-book-reader text-blue-400"></i>
                            <span class="text-sm font-medium">O'qilmoqda</span>
                            <span class="ml-auto text-xs bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 px-2 py-0.5 rounded-full" id="count-reading">0</span>
                        </button>
                        <button onclick="app.filterShelf('finished')" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-gray-100 dark:hover:bg-slate-700 transition-colors text-left group" data-shelf="finished">
                            <i class="fas fa-check-circle text-green-400"></i>
                            <span class="text-sm font-medium">O'qib bo'lingan</span>
                            <span class="ml-auto text-xs bg-green-100 dark:bg-green-900/30 text-green-600 dark:text-green-400 px-2 py-0.5 rounded-full" id="count-finished">0</span>
                        </button>
                        <button onclick="app.filterShelf('planned')" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-gray-100 dark:hover:bg-slate-700 transition-colors text-left group" data-shelf="planned">
                            <i class="fas fa-clock text-orange-400"></i>
                            <span class="text-sm font-medium">Rejadagi</span>
                            <span class="ml-auto text-xs bg-orange-100 dark:bg-orange-900/30 text-orange-600 dark:text-orange-400 px-2 py-0.5 rounded-full" id="count-planned">0</span>
                        </button>
                        <button onclick="app.filterShelf('bookmarks')" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-gray-100 dark:hover:bg-slate-700 transition-colors text-left group" data-shelf="bookmarks">
                            <i class="fas fa-bookmark text-purple-400"></i>
                            <span class="text-sm font-medium">Xatcho'plar</span>
                            <span class="ml-auto text-xs bg-purple-100 dark:bg-purple-900/30 text-purple-600 dark:text-purple-400 px-2 py-0.5 rounded-full" id="count-bookmarks">0</span>
                        </button>
                    </nav>
                </div>

                <!-- Recent Activity -->
                <div>
                    <h4 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3 px-2">So'nggi faoliyat</h4>
                    <div id="recent-activity" class="space-y-3 px-2">
                        <p class="text-xs text-gray-400 italic">Hali faoliyat yo'q...</p>
                    </div>
                </div>
            </div>

            <div class="p-4 border-t border-gray-200 dark:border-slate-700">
                <button onclick="app.toggleDarkMode()" class="w-full flex items-center justify-center gap-2 px-4 py-2.5 bg-gray-100 dark:bg-slate-700 hover:bg-gray-200 dark:hover:bg-slate-600 rounded-xl transition-colors text-sm font-medium">
                    <i class="fas fa-moon dark:hidden"></i>
                    <i class="fas fa-sun hidden dark:block text-yellow-400"></i>
                    <span class="dark:hidden">Tungi rejim</span>
                    <span class="hidden dark:block">Kunduzgi rejim</span>
                </button>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 flex flex-col h-full overflow-hidden relative">
            <!-- Mobile Header -->
            <header class="md:hidden bg-white dark:bg-slate-800 border-b border-gray-200 dark:border-slate-700 p-4 flex items-center justify-between z-30">
                <div class="flex items-center gap-2">
                    <i class="fas fa-book-open text-blue-600 text-xl"></i>
                    <span class="font-bold text-lg">Kutubxona</span>
                </div>
                <button onclick="document.querySelector('aside').classList.toggle('hidden'); document.querySelector('aside').classList.toggle('absolute'); document.querySelector('aside').classList.toggle('h-full');" class="p-2">
                    <i class="fas fa-bars text-xl"></i>
                </button>
            </header>

            <!-- Top Bar -->
            <div class="bg-white/80 dark:bg-slate-800/80 backdrop-blur-md border-b border-gray-200 dark:border-slate-700 p-4 md:p-6 z-10">
                <div class="max-w-7xl mx-auto">
                    <div class="flex flex-col md:flex-row gap-4 justify-between items-start md:items-center mb-4">
                        <div>
                            <h2 class="text-2xl font-bold text-gray-800 dark:text-white" id="page-title">Kitoblar katalogi</h2>
                            <p class="text-sm text-gray-500 dark:text-gray-400">Bugun nima o'qishni xohlaysiz?</p>
                        </div>
                        <div class="flex gap-2">
                            <select id="sort-select" onchange="app.renderBooks()" class="bg-gray-50 dark:bg-slate-700 border border-gray-200 dark:border-slate-600 text-gray-700 dark:text-gray-200 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block p-2.5">
                                <option value="newest">Eng yangilari</option>
                                <option value="rating">Reyting bo'yicha</option>
                                <option value="az">A-Z</option>
                            </select>
                        </div>
                    </div>

                    <!-- Search & Filters -->
                    <div class="flex flex-col lg:flex-row gap-3">
                        <div class="relative flex-1">
                            <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                                <i class="fas fa-search text-gray-400"></i>
                            </div>
                            <input type="text" id="search-input" oninput="app.renderBooks()" class="bg-gray-50 dark:bg-slate-700 border border-gray-200 dark:border-slate-600 text-gray-900 dark:text-white text-sm rounded-xl focus:ring-blue-500 focus:border-blue-500 block w-full pl-10 p-3 transition-all" placeholder="Kitob nomi, muallif yoki mavzu bo'yicha qidirish...">
                        </div>
                        <div class="flex gap-2 overflow-x-auto pb-1 lg:pb-0 scrollbar-hide">
                            <select id="genre-filter" onchange="app.renderBooks()" class="bg-gray-50 dark:bg-slate-700 border border-gray-200 dark:border-slate-600 text-gray-700 dark:text-gray-200 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block p-2.5 whitespace-nowrap">
                                <option value="">Barcha janrlar</option>
                                <option value="Badiiy">Badiiy</option>
                                <option value="Ilmiy">Ilmiy</option>
                                <option value="Fantastika">Fantastika</option>
                                <option value="Tarix">Tarix</option>
                                <option value="Psixologiya">Psixologiya</option>
                                <option value="Biznes">Biznes</option>
                                <option value="Bolalar">Bolalar</option>
                                <option value="Diniy">Diniy</option>
                                <option value="She'riyat">She'riyat</option>
                            </select>
                            <select id="lang-filter" onchange="app.renderBooks()" class="bg-gray-50 dark:bg-slate-700 border border-gray-200 dark:border-slate-600 text-gray-700 dark:text-gray-200 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block p-2.5 whitespace-nowrap">
                                <option value="">Barcha tillar</option>
                                <option value="O'zbek">O'zbek</option>
                                <option value="Rus">Rus</option>
                                <option value="Ingliz">Ingliz</option>
                            </select>
                            <select id="format-filter" onchange="app.renderBooks()" class="bg-gray-50 dark:bg-slate-700 border border-gray-200 dark:border-slate-600 text-gray-700 dark:text-gray-200 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block p-2.5 whitespace-nowrap">
                                <option value="">Barcha formatlar</option>
                                <option value="PDF">PDF</option>
                                <option value="EPUB">EPUB</option>
                                <option value="Audio">Audio</option>
                            </select>
                        </div>
                    </div>
                    
                    <!-- Active Filters Display -->
                    <div id="active-filters" class="flex flex-wrap gap-2 mt-3 empty:hidden"></div>
                </div>
            </div>

            <!-- Books Grid -->
            <div class="flex-1 overflow-y-auto p-4 md:p-6 bg-gray-50 dark:bg-slate-900" id="main-scroll">
                <div class="max-w-7xl mx-auto">
                    <div id="books-container" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                        <!-- Books will be injected here -->
                    </div>
                    
                    <!-- Empty State -->
                    <div id="empty-state" class="hidden flex flex-col items-center justify-center py-20 text-center">
                        <div class="w-24 h-24 bg-gray-100 dark:bg-slate-800 rounded-full flex items-center justify-center mb-4">
                            <i class="fas fa-search text-3xl text-gray-400"></i>
                        </div>
                        <h3 class="text-lg font-semibold text-gray-700 dark:text-gray-300">Kitoblar topilmadi</h3>
                        <p class="text-gray-500 dark:text-gray-400 max-w-xs mt-2">Qidiruv so'rovingizga mos keladigan kitoblar topilmadi. Boshqa so'z bilan urinib ko'ring.</p>
                        <button onclick="app.resetFilters()" class="mt-4 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-medium transition-colors">
                            Filterni tozalash
                        </button>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Reader Modal -->
    <div id="reader-modal" class="fixed inset-0 z-50 hidden">
        <div class="absolute inset-0 bg-black/60 backdrop-blur-sm transition-opacity" onclick="app.closeReader()"></div>
        <div class="absolute inset-x-0 bottom-0 md:inset-0 md:flex md:items-center md:justify-center pointer-events-none">
            <div class="bg-white dark:bg-slate-800 w-full md:w-[800px] md:h-[90vh] h-[85vh] md:rounded-2xl rounded-t-2xl shadow-2xl flex flex-col pointer-events-auto transform transition-transform duration-300 translate-y-full md:translate-y-0 scale-95 opacity-0" id="reader-content">
                
                <!-- Reader Header -->
                <div class="flex items-center justify-between p-4 border-b border-gray-200 dark:border-slate-700">
                    <div class="flex items-center gap-3 overflow-hidden">
                        <button onclick="app.closeReader()" class="p-2 hover:bg-gray-100 dark:hover:bg-slate-700 rounded-lg transition-colors">
                            <i class="fas fa-arrow-left"></i>
                        </button>
                        <div class="min-w-0">
                            <h3 class="font-bold text-gray-800 dark:text-white truncate" id="reader-title">Kitob nomi</h3>
                            <p class="text-xs text-gray-500 dark:text-gray-400 truncate" id="reader-author">Muallif</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-1">
                        <button onclick="app.changeFontSize(-1)" class="p-2 hover:bg-gray-100 dark:hover:bg-slate-700 rounded-lg text-gray-600 dark:text-gray-300" title="Kichraytirish">
                            <i class="fas fa-font text-xs"></i>
                        </button>
                        <button onclick="app.changeFontSize(1)" class="p-2 hover:bg-gray-100 dark:hover:bg-slate-700 rounded-lg text-gray-600 dark:text-gray-300" title="Kattalashtirish">
                            <i class="fas fa-font text-lg"></i>
                        </button>
                        <button onclick="app.toggleReaderTheme()" class="p-2 hover:bg-gray-100 dark:hover:bg-slate-700 rounded-lg text-gray-600 dark:text-gray-300" title="Rejimni o'zgartirish">
                            <i class="fas fa-adjust"></i>
                        </button>
                        <button onclick="app.speakText()" class="p-2 hover:bg-gray-100 dark:hover:bg-slate-700 rounded-lg text-gray-600 dark:text-gray-300" title="Ovozli o'qish">
                            <i class="fas fa-headphones"></i>
                        </button>
                        <button onclick="app.addBookmark()" class="p-2 hover:bg-gray-100 dark:hover:bg-slate-700 rounded-lg text-gray-600 dark:text-gray-300" title="Xatcho'p qo'shish">
                            <i class="far fa-bookmark"></i>
                        </button>
                    </div>
                </div>

                <!-- Reader Body -->
                <div class="flex-1 overflow-y-auto p-6 md:p-10 bg-white dark:bg-slate-800 transition-colors duration-300" id="reader-scroll-area">
                    <div id="reader-text" class="prose dark:prose-invert max-w-none text-gray-800 dark:text-gray-200 leading-relaxed transition-all duration-200" style="font-size: 18px;">
                        <!-- Content -->
                    </div>
                </div>

                <!-- Reader Footer -->
                <div class="p-4 border-t border-gray-200 dark:border-slate-700 flex justify-between items-center bg-gray-50 dark:bg-slate-800/50 rounded-b-2xl">
                    <span class="text-xs text-gray-500" id="reader-progress">0% o'qildi</span>
                    <div class="flex gap-2">
                        <button onclick="app.addToShelf(app.currentBook.id, 'reading')" class="px-3 py-1.5 text-xs font-medium bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 rounded-lg hover:bg-blue-200 transition-colors">
                            O'qilmoqda
                        </button>
                        <button onclick="app.addToShelf(app.currentBook.id, 'finished')" class="px-3 py-1.5 text-xs font-medium bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 rounded-lg hover:bg-green-200 transition-colors">
                            Tugallandi
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Toast Notification -->
    <div id="toast" class="fixed bottom-6 right-6 transform translate-y-20 opacity-0 transition-all duration-300 z-50 bg-gray-800 dark:bg-white text-white dark:text-gray-900 px-6 py-3 rounded-xl shadow-2xl flex items-center gap-3">
        <i class="fas fa-check-circle text-green-400 dark:text-green-600"></i>
        <span class="font-medium text-sm" id="toast-message">Amal bajarildi</span>
    </div>

    <script>
        // --- Data ---
        const initialBooks = [
            { id: 1, title: "Alkimyogar", author: "Paulo Koelyo", genre: "Badiiy", year: 1988, lang: "O'zbek", format: "EPUB", rating: 4.8, pages: 230, content: "Alkimyogar - bu o'z orzulariga ergashish haqidagi mashhur roman. Kitobda cho'pon bola Santyagoning xazinani topish sarguzashtlari tasvirlangan. U Misrdan Ispaniyagacha bo'lgan yo'lda ko'plab saboqlar oladi va o'zining shaxsiy afsonasini topadi. Bu asar millionlab kitobxonlarni ilhomlantirgan va ularning hayotini o'zgartirgan." },
            { id: 2, title: "1984", author: "Jorj Oruell", genre: "Fantastika", year: 1949, lang: "O'zbek", format: "PDF", rating: 5.0, pages: 350, content: "1984 - totalitar jamiyat haqidagi dahshatli roman. Asarda hamma narsani kuzatuvchi 'Katta birodar' va shaxsiy erkinlikning yo'qligi tasvirlangan. Uinston Smitning qarshilik ko'rsatishga urinishi va sevgi, sadoqat, haqiqat tushunchalarining qanday buzilishi haqida hikoya qiladi." },
            { id: 3, title: "Atom odatlar", author: "Jeyms Klir", genre: "Psixologiya", year: 2018, lang: "O'zbek", format: "EPUB", rating: 4.9, pages: 280, content: "Atom odatlar - kichik o'zgarishlar katta natijalarga olib kelishi haqidagi amaliy qo'llanma. Har kuni 1% yaxshilanish sizni muvaffaqiyatga olib boradi. Kitobda odatlarning qanday shakllanishi, ularni qanday o'zgartirish va yangi yaxshi odatlarni qandal shakllantirish haqida batafsil yoritilgan." },
            { id: 4, title: "The Great Gatsby", author: "F. Scott Fitzgerald", genre: "Badiiy", year: 1925, lang: "Ingliz", format: "PDF", rating: 4.5, pages: 200, content: "The Great Gatsby - Amerikaning jazz davri haqidagi klassik roman. Boylar va orzular haqida hikoya. Jay Gatsbyning boylik va sevgi orzulari, ammo ichki bo'shliq va yolg'on haqidagi tragik hikoya. Bu asar Amerikan orzu tushunchasining tanqidiy tahlili hisoblanadi." },
            { id: 5, title: "Sapiens", author: "Yuval Noah Harari", genre: "Tarix", year: 2011, lang: "O'zbek", format: "Audio", rating: 4.7, pages: 450, content: "Sapiens - insoniyatning qisqacha tarixi. Odamzodning evolyutsiyasi va jamiyat taraqqiyoti haqida. Homo sapiensning dunyoda ustunlik qilishining sirlari, dehqonchilik inqilobi, dinlar, imperiyalar va ilm-fanning rivojlanishi yoritilgan." },
            { id: 6, title: "Dumboq", author: "Tohir Malik", genre: "Badiiy", year: 2005, lang: "O'zbek", format: "EPUB", rating: 4.6, pages: 400, content: "Dumboq - o'zbek adabiyotining mashhur romani. Shaytanat va yovuzlikka qarshi kurash. Asarda insoniy fazilatlar, muhabbat va adolat timsoli bo'lgan qahramonlarning hayoti tasvirlangan." },
            { id: 7, title: "O'tkan kunlar", author: "Abdulla Qodiriy", genre: "Badiiy", year: 1922, lang: "O'zbek", format: "PDF", rating: 4.9, pages: 380, content: "O'tkan kunlar - o'zbek milliy romanining sardori. XIX asr oxiri - XX asr boshidagi Toshkent hayoti, an'analar va zamonaviy o'zgarishlar o'rtasidagi ziddiyatlar tasvirlangan. Asar o'zbek adabiyotining eng yuksak cho'qqilaridan biri hisoblanadi." },
            { id: 8, title: "Mehrobdan chayon", author: "Abdulla Qodiriy", genre: "Badiiy", year: 1928, lang: "O'zbek", format: "EPUB", rating: 4.8, pages: 320, content: "Mehrobdan chayon - o'zbek adabiyotining yana bir durdonasi. Asarda feudol tuzumning tanqidi, ayollar ozodligi va ilm-ma'rifat g'oyalari yoritilgan. Qahramonlarning taqdiri orqali muallif jamiyatdagi adolatsizliklarni fosh etadi." },
