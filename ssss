        // --- Application Logic ---
        const app = {
            books: [],
            userProfile: {
                reading: [],
                finished: [],
                planned: [],
                bookmarks: [],
                notes: []
            },
            currentBook: null,
            currentFontSize: 18,
            currentShelf: 'all',
            speech: null,

            init() {
                this.loadData();
                this.setupEventListeners();
                this.renderShelves();
                this.renderBooks();
                this.updateStats();
                this.checkDarkMode();
            },

            loadData() {
                const storedBooks = localStorage.getItem('library_books_v2');
                const storedProfile = localStorage.getItem('user_profile_v2');
                
                this.books = storedBooks ? JSON.parse(storedBooks) : [...initialBooks];
                if (!storedBooks) this.saveBooks();
                
                this.userProfile = storedProfile ? JSON.parse(storedProfile) : {
                    reading: [],
                    finished: [],
                    planned: [],
                    bookmarks: [],
                    notes: []
                };
            },

            saveBooks() {
                localStorage.setItem('library_books_v2', JSON.stringify(this.books));
            },

            saveProfile() {
                localStorage.setItem('user_profile_v2', JSON.stringify(this.userProfile));
                this.updateStats();
                this.renderShelves();
            },

            setupEventListeners() {
                // Close modal on escape
                document.addEventListener('keydown', (e) => {
                    if (e.key === 'Escape') this.closeReader();
                });
            },

            // --- Rendering ---
            renderBooks() {
                const container = document.getElementById('books-container');
                const emptyState = document.getElementById('empty-state');
                const searchTerm = document.getElementById('search-input').value.toLowerCase();
                const genre = document.getElementById('genre-filter').value;
                const lang = document.getElementById('lang-filter').value;
                const format = document.getElementById('format-filter').value;
                const sort = document.getElementById('sort-select').value;

                let filtered = this.books.filter(book => {
                    const matchesSearch = book.title.toLowerCase().includes(searchTerm) || 
                                         book.author.toLowerCase().includes(searchTerm) ||
                                         book.content.toLowerCase().includes(searchTerm);
                    const matchesGenre = !genre || book.genre === genre;
                    const matchesLang = !lang || book.lang === lang;
                    const matchesFormat = !format || book.format === format;
                    return matchesSearch && matchesGenre && matchesLang && matchesFormat;
                });

                // Shelf filtering
                if (this.currentShelf !== 'all') {
                    if (this.currentShelf === 'bookmarks') {
                        const bookmarkedIds = this.userProfile.bookmarks.map(b => b.bookId);
                        filtered = filtered.filter(b => bookmarkedIds.includes(b.id));
                    } else {
                        filtered = filtered.filter(b => this.userProfile[this.currentShelf].includes(b.id));
                    }
                }

                // Sorting
                if (sort === 'newest') filtered.sort((a, b) => b.year - a.year);
                else if (sort === 'rating') filtered.sort((a, b) => b.rating - a.rating);
                else if (sort === 'az') filtered.sort((a, b) => a.title.localeCompare(b.title));

                // Update active filters UI
                this.updateActiveFilters();

                if (filtered.length === 0) {
                    container.innerHTML = '';
                    emptyState.classList.remove('hidden');
                    return;
                }

                emptyState.classList.add('hidden');
                container.innerHTML = filtered.map(book => this.createBookCard(book)).join('');
            },

            createBookCard(book) {
                const isReading = this.userProfile.reading.includes(book.id);
                const isFinished = this.userProfile.finished.includes(book.id);
                const isPlanned = this.userProfile.planned.includes(book.id);
                
                let statusBadge = '';
                if (isReading) statusBadge = `<span class="absolute top-3 right-3 bg-blue-500 text-white text-xs px-2 py-1 rounded-full shadow-lg">O'qilmoqda</span>`;
                else if (isFinished) statusBadge = `<span class="absolute top-3 right-3 bg-green-500 text-white text-xs px-2 py-1 rounded-full shadow-lg">Tugallangan</span>`;
                else if (isPlanned) statusBadge = `<span class="absolute top-3 right-3 bg-orange-500 text-white text-xs px-2 py-1 rounded-full shadow-lg">Rejada</span>`;

                const genreColors = {
                    'Badiiy': 'bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-300',
                    'Ilmiy': 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300',
                    'Fantastika': 'bg-indigo-100 text-indigo-700 dark:bg-indigo-900/30 dark:text-indigo-300',
                    'Tarix': 'bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-300',
                    'Psixologiya': 'bg-pink-100 text-pink-700 dark:bg-pink-900/30 dark:text-pink-300',
                    'Biznes': 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-300',
                    'Bolalar': 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-300',
                    'Diniy': 'bg-teal-100 text-teal-700 dark:bg-teal-900/30 dark:text-teal-300',
                    'She\'riyat': 'bg-rose-100 text-rose-700 dark:bg-rose-900/30 dark:text-rose-300'
                };

                return `
                    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 book-card-hover border border-gray-100 dark:border-slate-700 overflow-hidden group relative cursor-pointer" onclick="app.openReader(${book.id})">
                        ${statusBadge}
                        <div class="p-6">
                            <div class="flex justify-between items-start mb-4">
                                <span class="px-2.5 py-1 rounded-lg text-xs font-semibold ${genreColors[book.genre] || 'bg-gray-100 text-gray-700'}">${book.genre}</span>
                                <div class="flex items-center gap-1 text-yellow-400">
                                    <i class="fas fa-star text-sm"></i>
                                    <span class="text-sm font-bold text-gray-700 dark:text-gray-300">${book.rating}</span>
                                </div>
                            </div>
                            
                            <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-1 line-clamp-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">${book.title}</h3>
                            <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">${book.author}</p>
                            
                            <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-3 mb-4 leading-relaxed">${book.content.substring(0, 120)}...</p>
                            
                            <div class="flex items-center justify-between pt-4 border-t border-gray-100 dark:border-slate-700">
                                <div class="flex items-center gap-3 text-xs text-gray-500 dark:text-gray-400">
                                    <span class="flex items-center gap-1"><i class="far fa-calendar"></i> ${book.year}</span>
                                    <span class="flex items-center gap-1"><i class="far fa-file-alt"></i> ${book.format}</span>
                                </div>
                                <span class="text-xs font-medium px-2 py-1 bg-gray-100 dark:bg-slate-700 rounded-md">${book.lang}</span>
                            </div>
                        </div>
                        
                        <!-- Quick Actions Overlay -->
                        <div class="absolute inset-x-0 bottom-0 p-4 bg-gradient-to-t from-white dark:from-slate-800 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex gap-2 justify-center translate-y-2 group-hover:translate-y-0">
                            <button onclick="event.stopPropagation(); app.addToShelf(${book.id}, 'reading')" class="p-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg shadow-lg transition-transform hover:scale-110" title="O'qilmoqda">
                                <i class="fas fa-book-reader"></i>
                            </button>
                            <button onclick="event.stopPropagation(); app.addToShelf(${book.id}, 'finished')" class="p-2 bg-green-600 hover:bg-green-700 text-white rounded-lg shadow-lg transition-transform hover:scale-110" title="Tugallandi">
                                <i class="fas fa-check"></i>
                            </button>
                            <button onclick="event.stopPropagation(); app.addToShelf(${book.id}, 'planned')" class="p-2 bg-orange-500 hover:bg-orange-600 text-white rounded-lg shadow-lg transition-transform hover:scale-110" title="Rejada">
                                <i class="fas fa-clock"></i>
                            </button>
                        </div>
                    </div>
                `;
            },

            renderShelves() {
                // Update counts
                document.getElementById('count-all').textContent = this.books.length;
                document.getElementById('count-reading').textContent = this.userProfile.reading.length;
                document.getElementById('count-finished').textContent = this.userProfile.finished.length;
                document.getElementById('count-planned').textContent = this.userProfile.planned.length;
                document.getElementById('count-bookmarks').textContent = this.userProfile.bookmarks.length;

                // Update active shelf UI
                document.querySelectorAll('[data-shelf]').forEach(el => {
                    if (el.dataset.shelf === this.currentShelf) {
                        el.classList.add('bg-blue-50', 'dark:bg-blue-900/20', 'text-blue-600', 'dark:text-blue-400');
                        el.classList.remove('text-gray-700', 'dark:text-gray-200');
                    } else {
                        el.classList.remove('bg-blue-50', 'dark:bg-blue-900/20', 'text-blue-600', 'dark:text-blue-400');
                        el.classList.add('text-gray-700', 'dark:text-gray-200');
                    }
                });

                // Update stats
                document.getElementById('stat-reading').textContent = this.userProfile.reading.length;
                document.getElementById('stat-finished').textContent = this.userProfile.finished.length;

                // Recent activity
                const recentContainer = document.getElementById('recent-activity');
                const recentBooks = [...this.userProfile.reading, ...this.userProfile.finished].slice(-3);
                if (recentBooks.length > 0) {
                    recentContainer.innerHTML = recentBooks.map(id => {
                        const book = this.books.find(b => b.id === id);
                        if (!book) return '';
                        const isFinished = this.userProfile.finished.includes(id);
                        return `
                            <div class="flex items-center gap-3 text-sm p-2 hover:bg-gray-50 dark:hover:bg-slate-700/50 rounded-lg cursor-pointer" onclick="app.openReader(${id})">
                                <div class="w-8 h-10 bg-gradient-to-br from-blue-400 to-purple-500 rounded shadow-sm flex-shrink-0"></div>
                                <div class="min-w-0">
                                    <p class="font-medium truncate text-gray-800 dark:text-gray-200">${book.title}</p>
                                    <p class="text-xs text-gray-500">${isFinished ? 'Tugallangan' : 'O\'qilmoqda'}</p>
                                </div>
                            </div>
                        `;
                    }).join('');
                }
            },

            updateStats() {
                this.renderShelves();
            },

            updateActiveFilters() {
                const container = document.getElementById('active-filters');
                const filters = [];
                
                const genre = document.getElementById('genre-filter').value;
                const lang = document.getElementById('lang-filter').value;
                const format = document.getElementById('format-filter').value;
                const search = document.getElementById('search-input').value;

                if (search) filters.push({ type: 'search', label: `Qidiruv: "${search}"` });
                if (genre) filters.push({ type: 'genre', label: genre });
                if (lang) filters.push({ type: 'lang', label: lang });
                if (format) filters.push({ type: 'format', label: format });

                container.innerHTML = filters.map(f => `
                    <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300">
                        ${f.label}
                        <button onclick="app.clearFilter('${f.type}')" class="hover:text-blue-600 dark:hover:text-blue-200">
                            <i class="fas fa-times"></i>
                        </button>
                    </span>
                `).join('');
            },

            // --- Actions ---
            filterShelf(shelf) {
                this.currentShelf = shelf;
                const titles = {
                    'all': 'Kitoblar katalogi',
                    'reading': 'O\'qilayotgan kitoblar',
                    'finished': 'O\'qib bo\'lingan kitoblar',
                    'planned': 'Rejadagi kitoblar',
                    'bookmarks': 'Xatcho\'plar'
                };
                document.getElementById('page-title').textContent = titles[shelf];
                this.renderBooks();
                this.renderShelves();
            },

            clearFilter(type) {
                if (type === 'search') document.getElementById('search-input').value = '';
                if (type === 'genre') document.getElementById('genre-filter').value = '';
                if (type === 'lang') document.getElementById('lang-filter').value = '';
                if (type === 'format') document.getElementById('format-filter').value = '';
                this.renderBooks();
            },

            resetFilters() {
                document.getElementById('search-input').value = '';
                document.getElementById('genre-filter').value = '';
                document.getElementById('lang-filter').value = '';
                document.getElementById('format-filter').value = '';
                this.renderBooks();
            },

            addToShelf(bookId, shelfType) {
                // Remove from other shelves
                ['reading', 'finished', 'planned'].forEach(s => {
                    this.userProfile[s] = this.userProfile[s].filter(id => id !== bookId);
                });

                if (shelfType !== 'remove') {
                    this.userProfile[shelfType].push(bookId);
                    this.showToast(`Kitob "${shelfType === 'reading' ? 'O\'qilmoqda' : shelfType === 'finished' ? 'Tugallangan' : 'Rejada'} javoniga qo'shildi`);
                } else {
                    this.showToast('Kitob javondan olib tashlandi');
                }

                this.saveProfile();
                this.renderBooks();
            },

            // --- Reader ---
            openReader(bookId) {
                const book = this.books.find(b => b.id === bookId);
                if (!book) return;

                this.currentBook = book;
                document.getElementById('reader-title').textContent = book.title;
                document.getElementById('reader-author').textContent = book.author;
                document.getElementById('reader-text').innerHTML = `<p class="mb-4">${book.content}</p><p class="text-gray-400 italic text-center mt-8">--- Demo kontent tugadi ---</p>`;
                document.getElementById('reader-text').style.fontSize = this.currentFontSize + 'px';
                
                const modal = document.getElementById('reader-modal');
                const content = document.getElementById('reader-content');
                modal.classList.remove('hidden');
                
                // Animation
                setTimeout(() => {
                    content.classList.remove('translate-y-full', 'scale-95', 'opacity-0');
                    content.classList.add('translate-y-0', 'scale-100', 'opacity-100');
                }, 10);

                // Check bookmarks
                this.updateBookmarkIcon();
            },

            closeReader() {
                const modal = document.getElementById('reader-modal');
                const content = document.getElementById('reader-content');
                
                content.classList.remove('translate-y-0', 'scale-100', 'opacity-100');
                content.classList.add('translate-y-full', 'scale-95', 'opacity-0');
                
                if (this.speech) window.speechSynthesis.cancel();

                setTimeout(() => {
                    modal.classList.add('hidden');
                    this.currentBook = null;
                }, 300);
            },

            changeFontSize(delta) {
                this.currentFontSize = Math.max(12, Math.min(32, this.currentFontSize + delta));
                document.getElementById('reader-text').style.fontSize = this.currentFontSize + 'px';
            },

            toggleReaderTheme() {
                document.getElementById('reader-scroll-area').classList.toggle('bg-amber-50');
                document.getElementById('reader-scroll-area').classList.toggle('text-gray-900');
                document.getElementById('reader-scroll-area').classList.toggle('dark:bg-slate-800');
                document.getElementById('reader-scroll-area').classList.toggle('dark:text-gray-200');
            },

            speakText() {
                if (!this.currentBook) return;
                if (this.speech) {
                    window.speechSynthesis.cancel();
                    this.speech = null;
                    return;
                }
                
                const text = document.getElementById('reader-text').innerText;
                const utterance = new SpeechSynthesisUtterance(text);
                utterance.lang = 'uz-UZ';
                utterance.onend = () => { this.speech = null; };
                window.speechSynthesis.speak(utterance);
                this.speech = utterance;
            },

            addBookmark() {
                if (!this.currentBook) return;
                
                const existing = this.userProfile.bookmarks.find(b => b.bookId === this.currentBook.id);
                if (existing) {
                    this.userProfile.bookmarks = this.userProfile.bookmarks.filter(b => b.bookId !== this.currentBook.id);
                    this.showToast('Xatcho\'p olib tashlandi');
                } else {
                    this.userProfile.bookmarks.push({
                        bookId: this.currentBook.id,
                        date: new Date().toISOString()
                    });
                    this.showToast('Xatcho\'p qo\'shildi');
                }
                
                this.saveProfile();
                this.updateBookmarkIcon();
                this.renderBooks();
            },

            updateBookmarkIcon() {
                const btn = document.querySelector('#reader-modal .fa-bookmark').parentElement;
                const isBookmarked = this.userProfile.bookmarks.some(b => b.bookId === this.currentBook?.id);
                if (isBookmarked) {
                    btn.innerHTML = '<i class="fas fa-bookmark text-purple-500"></i>';
                } else {
                    btn.innerHTML = '<i class="far fa-bookmark"></i>';
                }
            },

            // --- Utilities ---
            toggleDarkMode() {
                document.documentElement.classList.toggle('dark');
                const isDark = document.documentElement.classList.contains('dark');
                localStorage.setItem('darkMode', isDark);
            },

            checkDarkMode() {
                if (localStorage.getItem('darkMode') === 'true' || 
                    (!localStorage.getItem('darkMode') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                    document.documentElement.classList.add('dark');
                }
            },

            showToast(message) {
                const toast = document.getElementById('toast');
                document.getElementById('toast-message').textContent = message;
                toast.classList.remove('translate-y-20', 'opacity-0');
                
                setTimeout(() => {
                    toast.classList.add('translate-y-20', 'opacity-0');
                }, 3000);
            }
        };

        // Initialize
        document.addEventListener('DOMContentLoaded', () => {
            app.init();
        });
    </script>
</body>
</html>
