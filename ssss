            { id: 49, title: "The Great Divorce", author: "C.S. Lewis", genre: "Diniy", year: 1945, lang: "Ingliz", format: "EPUB", rating: 4.6, pages: 150, content: "The Great Divorce - jannat va do'zax haqidagi alegorik asar. Insonning ozod tanlovi va uning abadiy taqdiri haqidagi chuqur fikrlar." },
            { id: 50, title: "Mere Christianity", author: "C.S. Lewis", genre: "Diniy", year: 1952, lang: "Ingliz", format: "PDF", rating: 4.8, pages: 250, content: "Mere Christianity - Xristian dinining asosiy tamoyillarini mantiqiy va falsafiy jihatdan tushuntiruvchi asar. Imon, axloq va inson tabiati haqida." }
